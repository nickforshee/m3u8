#!/usr/bin/env bash
set -uo pipefail

VERSION="1.0.0"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG_FILE="$INSTALL_ROOT/config"
DEFAULT_OUTPUT="$HOME/Downloads"
DEFAULT_FFMPEG="$INSTALL_ROOT/tools/ffmpeg"

info(){ printf '\033[0;34m[INFO]\033[0m %s\n' "$*"; }
success(){ printf '\033[0;32m[SUCCESS]\033[0m %s\n' "$*"; }
warn(){ printf '\033[1;33m[WARNING]\033[0m %s\n' "$*"; }
die(){ printf '\033[0;31m[ERROR]\033[0m %s\n' "$*" >&2; exit 1; }

expand_path(){ case "$1" in "~") printf '%s\n' "$HOME";; "~/"*) printf '%s/%s\n' "$HOME" "${1:2}";; *) printf '%s\n' "$1";; esac; }
config_get(){
  local key="$1" line value
  [[ -r "$CONFIG_FILE" ]] || return 1
  line="$(grep -E "^${key}=" "$CONFIG_FILE" | tail -n1 || true)"
  [[ -n "$line" ]] || return 1
  value="${line#*=}"
  value="${value#\"}"; value="${value%\"}"
  printf '%s\n' "$value"
}
config_set(){
  local key="$1" value="$2" tmp
  mkdir -p "$(dirname "$CONFIG_FILE")"
  touch "$CONFIG_FILE"; chmod 600 "$CONFIG_FILE"
  tmp="$(mktemp)"
  grep -Ev "^${key}=" "$CONFIG_FILE" > "$tmp" || true
  printf '%s="%s"\n' "$key" "${value//\"/\\\"}" >> "$tmp"
  mv "$tmp" "$CONFIG_FILE"; chmod 600 "$CONFIG_FILE"
}

OUTDIR="${M3U8_OUTPUT_DIR:-$(config_get M3U8_OUTPUT_DIR || printf '%s' "$DEFAULT_OUTPUT")}"; OUTDIR="$(expand_path "$OUTDIR")"
FFMPEG="${M3U8_FFMPEG:-$(config_get M3U8_FFMPEG || printf '%s' "$DEFAULT_FFMPEG")}"; FFMPEG="$(expand_path "$FFMPEG")"

require_ffmpeg(){ [[ -x "$FFMPEG" ]] || die "FFmpeg is not executable at $FFMPEG. Run: m3u8 --doctor"; }
require_curl(){ command -v curl >/dev/null 2>&1 || die "curl is required."; }
valid_url(){ [[ "$1" =~ ^https?:// ]]; }
url_basename(){
  local url="${1%%\?*}" base
  base="${url##*/}"; base="${base%.m3u8}"
  [[ -n "$base" && "$base" != "playlist" && "$base" != "master" && "$base" != "index" ]] || base="video"
  printf '%s\n' "$base" | tr -cs 'A-Za-z0-9._-' '_'
}
clipboard_url(){
  local value=""
  if command -v pbpaste >/dev/null 2>&1; then value="$(pbpaste 2>/dev/null || true)"
  elif command -v wl-paste >/dev/null 2>&1; then value="$(wl-paste -n 2>/dev/null || true)"
  elif command -v xclip >/dev/null 2>&1; then value="$(xclip -selection clipboard -o 2>/dev/null || true)"; fi
  value="$(printf '%s' "$value" | head -n1 | tr -d '\r')"
  valid_url "$value" && printf '%s\n' "$value"
}
prompt(){ local label="$1" default="${2:-}" answer=""; [[ -r /dev/tty ]] || { printf '%s\n' "$default"; return; }; if [[ -n "$default" ]]; then printf '%s [%s]: ' "$label" "$default" >/dev/tty; else printf '%s: ' "$label" >/dev/tty; fi; IFS= read -r answer </dev/tty || true; printf '%s\n' "${answer:-$default}"; }

resolve_url(){
  local base="$1" rel="$2"
  [[ "$rel" =~ ^https?:// ]] && { printf '%s\n' "$rel"; return; }
  if [[ "$rel" == /* ]]; then printf '%s%s\n' "$(printf '%s' "$base" | sed -E 's#^(https?://[^/]+).*$#\1#')" "$rel"
  else printf '%s/%s\n' "${base%/*}" "$rel"; fi
}
select_variant(){
  local url="$1" playlist lines=() urls=() labels=() line next bw res i choice
  require_curl
  playlist="$(curl -fsSL --retry 3 "$url" 2>/dev/null || true)"
  grep -q '#EXT-X-STREAM-INF' <<<"$playlist" || { printf '%s\n' "$url"; return; }
  while IFS= read -r line; do lines+=("$line"); done <<<"$playlist"
  for ((i=0;i<${#lines[@]};i++)); do
    line="${lines[$i]}"
    [[ "$line" == \#EXT-X-STREAM-INF:* ]] || continue
    bw="$(sed -nE 's/.*BANDWIDTH=([0-9]+).*/\1/p' <<<"$line")"
    res="$(sed -nE 's/.*RESOLUTION=([^,]+).*/\1/p' <<<"$line")"
    next=""
    while ((++i < ${#lines[@]})); do [[ -n "${lines[$i]}" && "${lines[$i]}" != \#* ]] && { next="${lines[$i]}"; break; }; done
    [[ -n "$next" ]] || continue
    urls+=("$(resolve_url "$url" "$next")")
    labels+=("${res:-unknown resolution} — $(( ${bw:-0} / 1000 )) kbps")
  done
  ((${#urls[@]})) || { printf '%s\n' "$url"; return; }
  if [[ ! -r /dev/tty ]]; then printf '%s\n' "${urls[0]}"; return; fi
  printf '\nAvailable streams:\n' >/dev/tty
  for i in "${!urls[@]}"; do printf '  %d) %s\n' "$((i+1))" "${labels[$i]}" >/dev/tty; done
  choice="$(prompt 'Select quality' '1')"
  [[ "$choice" =~ ^[0-9]+$ ]] && ((choice>=1 && choice<=${#urls[@]})) || die "Invalid stream selection."
  printf '%s\n' "${urls[$((choice-1))]}"
}

human_size(){ local f="$1" bytes; bytes=$(wc -c <"$f" | tr -d ' '); awk -v b="$bytes" 'BEGIN{split("B KB MB GB TB",u); i=1; while(b>=1024&&i<5){b/=1024;i++} printf "%.1f %s",b,u[i]}' ; }
format_elapsed(){ local s="$1"; printf '%02d:%02d:%02d' $((s/3600)) $(((s%3600)/60)) $((s%60)); }
choose_collision(){
  local path="$1" answer stem ext n=1
  [[ ! -e "$path" ]] && { printf '%s\n' "$path"; return; }
  if [[ "${OVERWRITE:-false}" == true ]]; then printf '%s\n' "$path"; return; fi
  [[ -r /dev/tty ]] || die "Output exists: $path (use --overwrite)."
  printf '%s already exists. [o]verwrite, [r]ename, or [c]ancel? ' "$path" >/dev/tty; IFS= read -r answer </dev/tty || true
  case "${answer:-c}" in
    o|O) printf '%s\n' "$path";;
    r|R) stem="${path%.*}"; ext="${path##*.}"; while [[ -e "${stem}_$n.$ext" ]]; do ((n++)); done; printf '%s\n' "${stem}_$n.$ext";;
    *) exit 1;;
  esac
}

run_ffmpeg(){
  local url="$1" outfile="$2" audio_only="$3"
  local common=(-hide_banner -loglevel warning -stats -stats_period 1 -rw_timeout 15000000 -reconnect 1 -reconnect_streamed 1 -reconnect_delay_max 10 -protocol_whitelist file,http,https,tcp,tls,crypto -i "$url")
  if [[ "$audio_only" == true ]]; then "$FFMPEG" "${common[@]}" -vn -c:a aac -b:a 192k -movflags +faststart -y "$outfile"
  elif "$FFMPEG" "${common[@]}" -c copy -bsf:a aac_adtstoasc -movflags +faststart -y "$outfile"; then return 0
  else warn "Fast remux failed; retrying with AAC audio conversion."; "$FFMPEG" "${common[@]}" -c:v copy -c:a aac -movflags +faststart -y "$outfile"; fi
}

download_cmd(){
  local url="" filename="" outdir="$OUTDIR" audio_only=false start end selected tempdir outfile ext base clip
  OVERWRITE=false
  while (($#)); do case "$1" in
    -o|--output) shift; filename="${1:-}";; --output-dir) shift; outdir="$(expand_path "${1:-}")";; --overwrite|-y) OVERWRITE=true;; --audio-only) audio_only=true;; --) shift; break;; -*) die "Unknown option: $1";; *) [[ -z "$url" ]] && url="$1" || die "Unexpected argument: $1";; esac; shift; done
  if [[ -z "$url" ]]; then
    clip="$(clipboard_url || true)"
    if [[ -n "$clip" && -r /dev/tty ]]; then local use; use="$(prompt 'Use URL from clipboard? (Y/n)' 'Y')"; [[ "$use" =~ ^[Yy] ]] && url="$clip"; fi
    [[ -n "$url" ]] || url="$(prompt 'M3U8 URL' '')"
  fi
  valid_url "$url" || die "A valid http(s) URL is required."
  require_ffmpeg; mkdir -p "$outdir" || die "Cannot create output directory: $outdir"; [[ -w "$outdir" ]] || die "Output directory is not writable: $outdir"
  selected="$(select_variant "$url")"
  base="$(url_basename "$url")"; ext=mp4; [[ "$audio_only" == true ]] && ext=m4a
  if [[ -z "$filename" ]]; then filename="$(prompt 'Output filename' "$base.$ext")"; fi
  [[ "$filename" == *.* ]] || filename="$filename.$ext"
  [[ "$filename" == /* ]] && outfile="$filename" || outfile="$outdir/$filename"
  outfile="$(choose_collision "$outfile")"
  tempdir="$(mktemp -d "${TMPDIR:-/tmp}/m3u8.XXXXXX")"; trap "rm -rf -- '$tempdir'; rm -f -- '$outfile'" INT TERM; trap "rm -rf -- '$tempdir'" EXIT
  start=$(date +%s)
  info "Downloading to $outfile"
  if run_ffmpeg "$selected" "$outfile" "$audio_only" && [[ -s "$outfile" ]]; then
    end=$(date +%s); success "Download complete"; printf 'File: %s\nSize: %s\nElapsed: %s\n' "$outfile" "$(human_size "$outfile")" "$(format_elapsed $((end-start)))"
  else rm -f "$outfile"; die "Download failed."; fi
}

info_cmd(){ local url="${1:-}"; [[ -n "$url" ]] || die "Missing URL."; require_ffmpeg; "$FFMPEG" -hide_banner -i "$url"; }
validate_cmd(){ local file="${1:-}"; [[ -f "$file" ]] || die "File not found: $file"; require_ffmpeg; "$FFMPEG" -hide_banner -v error -i "$file" -f null - && success "File is valid."; }

doctor_cmd(){
  local ok=true profile alias
  printf 'm3u8 version: %s\nInstall root: %s\nConfig: %s\nPlatform: %s %s\n' "$VERSION" "$INSTALL_ROOT" "$CONFIG_FILE" "$(uname -s)" "$(uname -m)"
  [[ -r "$CONFIG_FILE" ]] && echo 'Config status: OK' || { echo 'Config status: MISSING'; ok=false; }
  [[ -x "$FFMPEG" ]] && { echo "FFmpeg: OK ($FFMPEG)"; "$FFMPEG" -version 2>/dev/null | head -n1; } || { echo "FFmpeg: MISSING ($FFMPEG)"; ok=false; }
  [[ -d "$OUTDIR" && -w "$OUTDIR" ]] && echo "Output directory: OK ($OUTDIR)" || { echo "Output directory: NOT WRITABLE ($OUTDIR)"; ok=false; }
  profile="$(config_get M3U8_SHELL_PROFILE || true)"; alias="$(config_get M3U8_ALIAS || true)"; echo "Shell profile: ${profile:-not configured}"; echo "Alias: ${alias:-none}"
  command -v curl >/dev/null && echo 'curl: OK' || { echo 'curl: MISSING'; ok=false; }
  [[ "$ok" == true ]] || return 1
}

configure_cmd(){
  local output ffmpeg
  output="$(prompt 'Default download directory' "$OUTDIR")"; output="$(expand_path "$output")"
  ffmpeg="$(prompt 'FFmpeg executable' "$FFMPEG")"; ffmpeg="$(expand_path "$ffmpeg")"
  mkdir -p "$output" || die "Cannot create $output"; [[ -x "$ffmpeg" ]] || die "FFmpeg is not executable: $ffmpeg"
  config_set M3U8_OUTPUT_DIR "$output"; config_set M3U8_FFMPEG "$ffmpeg"; success "Configuration updated."
}

show_help(){ cat <<'HELP'
Usage:
  m3u8 [download] [options] [URL]
  m3u8 info URL
  m3u8 validate FILE
  m3u8 --configure
  m3u8 --doctor
  m3u8 --version

Download options:
  -o, --output FILE       Output filename or absolute path
      --output-dir DIR    Override the configured output directory
  -y, --overwrite         Replace an existing output file
      --audio-only        Save audio as M4A

With no URL, m3u8 can use a clipboard URL or prompt interactively.
HELP
}

case "${1:-}" in
  download) shift; download_cmd "$@";;
  info) shift; info_cmd "$@";; validate) shift; validate_cmd "$@";;
  --configure|configure) configure_cmd;; --doctor|doctor) doctor_cmd;;
  --version|-v) echo "m3u8 $VERSION";; --help|-h|help) show_help;;
  "") download_cmd;;
  http://*|https://*) download_cmd "$@";;
  *) die "Unknown command or URL: $1 (run m3u8 --help)";;
esac
